---
import { site, aboutValues, skills, whatsappLink, whatsappMessages } from '../data/site';
import SectionTitle from './SectionTitle.astro';
import Icon from './Icon.astro';
---

<section class="about section" id="sobre">
  <div class="container">
    <div class="about__layout">
      <div class="reveal reveal--left">
        <SectionTitle
          kicker="Sobre Nós"
          titleStart="Proteger seu direito é"
          titleScript="garantir seu amanhã"
        />
        <p class="about__text-lead">
          Nosso escritório de advocacia combina o rigor técnico com uma visão estratégica
          para lutar por seus benefícios e indenizações, garantindo a proteção que você
          e sua família tanto precisam.
        </p>

        <ul class="about__values">
          {aboutValues.map((value) => (
            <li><Icon name="check" />{value}</li>
          ))}
        </ul>

        <div class="skills">
          {skills.map((skill) => (
            <div class="skill">
              <div class="skill__head">
                <span>{skill.label}</span>
                <span>{skill.value}%</span>
              </div>
              <div class="skill__bar">
                <div class="skill__fill" style={`--value:${skill.value}%`}></div>
              </div>
            </div>
          ))}
        </div>

        <a class="btn" href={whatsappLink(whatsappMessages.default)} target="_blank" rel="noopener noreferrer">
          <Icon name="whatsapp" />
          Falar com Especialista
        </a>
      </div>

      <div class="about__media reveal reveal--right" data-delay="1">
        <div class="about__symbol">
          <img src="/images/simbolo.webp" alt="Símbolo da marca Amuy Menezes" width="100" height="96" loading="lazy" />
        </div>
        <div class="about__frame">
          <img src="/images/escritorio.webp" alt="Escritório Amuy Menezes Advocacia" width="570" height="670" loading="lazy" />
        </div>
        <figure class="about__quote">
          <Icon name="quote" />
          <blockquote>"A verdade nunca prejudica uma causa que é justa."</blockquote>
          <cite>
            Dra. Dalyla Amuy
            <small>Inscrita na OAB/GO sob o nº 60.407</small>
          </cite>
        </figure>
      </div>
    </div>
  </div>
</section>
