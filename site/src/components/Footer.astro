---
import { site, navLinks, whatsappLink, whatsappMessages } from '../data/site';
import Icon from './Icon.astro';

// Fora da home, as âncoras precisam apontar para "/#âncora".
const isHome = Astro.url.pathname === '/';
const hrefFor = (href: string) => (isHome || !href.startsWith('#') ? href : `/${href}`);
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div>
        <img class="footer__logo" src="/images/logo.webp" alt="Logo Amuy Menezes Advocacia" width="176" />
        <p class="footer__tagline">{site.tagline}</p>
        <div class="footer__social">
          <a class="social-btn" href={site.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <Icon name="instagram" />
          </a>
          <a class="social-btn" href={site.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <Icon name="facebook" />
          </a>
          <a class="social-btn" href={site.social.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube">
            <Icon name="youtube" />
          </a>
        </div>
      </div>

      <div>
        <h4>Navegação</h4>
        <ul class="footer__links">
          {navLinks.map((link) => (
            <li><a href={hrefFor(link.href)}><Icon name="arrow-right" />{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4>Políticas</h4>
        <ul class="footer__links">
          <li><a href="/privacidade"><Icon name="arrow-right" />Privacidade</a></li>
          <li><a href="/cookies"><Icon name="arrow-right" />Cookies</a></li>
        </ul>
      </div>

      <div>
        <h4>Fale Conosco</h4>
        <ul class="footer__contact">
          <li>
            <Icon name="scale" />
            <a href={site.oabUrl} target="_blank" rel="noopener noreferrer">{site.oab}</a>
          </li>
          <li>
            <Icon name="phone" />
            <a href={site.phone.href}>{site.phone.label}</a>
          </li>
          <li>
            <Icon name="mail" />
            <a href={`mailto:${site.email}`}>{site.email}</a>
          </li>
          <li>
            <Icon name="whatsapp" />
            <a href={whatsappLink(whatsappMessages.default)} target="_blank" rel="noopener noreferrer">
              Atendimento pelo WhatsApp
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer__bar">
      <div class="footer__bar-inner">
        <p>Amuy Menezes © <span data-year>2025</span>. Todos os direitos reservados.</p>
        <div class="footer__legal">
          <a href="/privacidade">Privacidade</a>
          <a href="/cookies">Cookies</a>
        </div>
      </div>
    </div>
  </div>
</footer>
