# =====================================================
# Amuy Menezes Advocacia — Cache e Compressão
# Compatível com Apache 2.4+ e LiteSpeed (cPanel/LWS)
# =====================================================

# ---------- Tipos MIME ----------
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType font/woff2 .woff2
</IfModule>

# ---------- Compressão de texto ----------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ---------- Expiração por tipo de arquivo ----------
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML: sempre revalidar (conteúdo muda a cada deploy)
  ExpiresByType text/html "access plus 0 seconds"

  # CSS e JS do Astro (nomes com hash): 1 ano
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"

  # Fontes: 1 ano
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"

  # Imagens (nomes fixos): 1 mês
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"

  # Favicon: 1 semana
  ExpiresByType image/x-icon "access plus 1 week"
  ExpiresByType image/vnd.microsoft.icon "access plus 1 week"
</IfModule>

# ---------- Cache-Control refinado ----------
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Arquivos de /_astro/ têm hash no nome: cache longo e imutável
  RewriteRule ^_astro/ - [E=CACHE_LONG:1]
</IfModule>

<IfModule mod_headers.c>
  Header set Cache-Control "public, max-age=31536000, immutable" env=CACHE_LONG

  # HTML nunca servido de cache sem revalidação
  <FilesMatch "\.html?$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
